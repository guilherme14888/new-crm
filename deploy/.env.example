# Copie para deploy/.env e preencha. (NÃO comitar o .env real — já está no .gitignore)

# ── Imagens ──────────────────────────────────────────────────────────────────
REGISTRY=guilherme1488             # seu usuário/organização no DockerHub
TAG=latest                         # ou fixe a versão: v1.30.0

# ── Domínio / Traefik ────────────────────────────────────────────────────────
DOMAIN=sistema.br4licitacoes.com
CERT_RESOLVER=le                   # nome do certresolver do seu Traefik

# ── Banco (MariaDB externo) ──────────────────────────────────────────────────
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# ── Segredos (ESTÁVEIS — se trocar, tokens e chaves cifradas quebram) ─────────
JWT_SECRET=
AI_KEY_SECRET=                     # segredo da cripto das chaves (IA, 2Captcha)

# ── Scraping ─────────────────────────────────────────────────────────────────
SCRAPE_INTERVAL_HOURS=12
CAPTCHA_API_KEY=                   # opcional — a chave 2Captcha também é cadastrada na UI
