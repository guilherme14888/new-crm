PORT=3001

DB_HOST=localhost
DB_PORT=3306
DB_USER=crm
DB_PASSWORD=your_password_here
DB_NAME=crmbr4

JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ── Ingestão de licitações (Inteligência de Mercado) ──────────────────────────
# Agendador interno: roda todo dia às 09h BRT enquanto o servidor estiver no ar.
INGEST_ENABLED=true
INGEST_HOUR_BRT=9
INGEST_PAGES=10
# Recuperação de dias não executados (catch-up):
INGEST_CATCHUP_ON_BOOT=true        # ao subir, reconhece e recupera dias perdidos
INGEST_MAX_BACKFILL_DAYS=14        # janela máxima de recuperação (dias)

# Filtro de relevância por contexto (opcional, via IA). Sem isto vale só o filtro
# de "negativos" cadastrado em cada palavra-chave (rápido e sem custo).
# Pipeline de custo: T0 negativos → T1 cache exato → T2 cache semântico → T3 LLM.
INGEST_AI_RELEVANCE=false
INGEST_AI_MODEL=claude-haiku-4-5-20251001
INGEST_AI_BATCH=25                # itens por chamada do LLM (lote)
ANTHROPIC_API_KEY=

# Cache semântico (banco vetorial no MariaDB). Liga sozinho se houver chave de
# embeddings. Reduz custo: item parecido reaproveita veredito sem chamar o LLM.
EMBEDDINGS_PROVIDER=              # voyage | openai (auto pela chave presente)
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3.5-lite
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
INGEST_SEM_THRESHOLD=0.12         # distância cosine máx. p/ reaproveitar veredito

# Observação: credenciais dos portais e palavras-chave agora ficam no banco
# (Configurações → API Externa / Palavras-Chave), POR TENANT. As variáveis de
# portal abaixo permanecem apenas como fallback global opcional.

# Credenciais dos portais autenticados (NÃO comitar o .env real).
# Preencha apenas os que você usa; o conector correspondente passa a ter acesso.
EFFECTI_USER=
EFFECTI_PASS=
CONLICITACAO_TOKEN=
FORSETI_USER=
FORSETI_PASS=
COMPRASBR_USER=
COMPRASBR_PASS=

# Licitaja — API REST oficial (https://app.swaggerhub.com/apis-docs/bidhits/licitaja-br)
# Gere a API Key na sua conta Licitaja. Sem ela, resultados são parciais.
LICITAJA_API_KEY=
LICITAJA_BASE=https://www.licitaja.com.br/api/v1

# BLL/BLLCompras — Web Service SOAP de RESULTADOS (integração do órgão promotor).
# NÃO faz busca por palavra-chave: puxa processos cujo número você já conhece.
BLL_ORG_KEY=
BLL_WS_URL=https://lanceinteg.com/ProcessResult.svc
# Lista de processos a acompanhar (JSON em uma linha):
# BLL_PROCESSES=[{"number":"005/2016","modalityId":1,"agency":"Prefeitura X","uf":"PR","cnpj":"00000000000000"}]
BLL_PROCESSES=
